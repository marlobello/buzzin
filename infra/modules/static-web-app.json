{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "5248546966818585554"
    }
  },
  "parameters": {
    "name": {
      "type": "string",
      "metadata": {
        "description": "Static Web App resource name"
      }
    },
    "location": {
      "type": "string",
      "allowedValues": [
        "eastus2",
        "centralus",
        "westus2",
        "westeurope",
        "eastasia"
      ],
      "metadata": {
        "description": "Azure region. Free SWA is available only in select regions."
      }
    },
    "storageConnectionString": {
      "type": "securestring",
      "metadata": {
        "description": "Azure Storage connection string (passed as Function app setting)"
      }
    },
    "signalrConnectionString": {
      "type": "securestring",
      "metadata": {
        "description": "Azure SignalR connection string (passed as Function app setting)"
      }
    },
    "repoOwner": {
      "type": "string",
      "metadata": {
        "description": "GitHub repository owner"
      }
    },
    "repoName": {
      "type": "string",
      "metadata": {
        "description": "GitHub repository name"
      }
    }
  },
  "resources": {
    "swa": {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('name')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Free",
        "tier": "Free"
      },
      "properties": {
        "repositoryUrl": "[format('https://github.com/{0}/{1}', parameters('repoOwner'), parameters('repoName'))]",
        "branch": "main",
        "buildProperties": {
          "appLocation": "/",
          "apiLocation": "api",
          "outputLocation": "build",
          "skipGithubActionWorkflowGeneration": true
        },
        "stagingEnvironmentPolicy": "Disabled"
      }
    },
    "swaAppSettings": {
      "type": "Microsoft.Web/staticSites/config",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('name'), 'appsettings')]",
      "properties": {
        "AZURE_STORAGE_CONNECTION_STRING": "[parameters('storageConnectionString')]",
        "AZURE_SIGNALR_CONNECTION_STRING": "[parameters('signalrConnectionString')]"
      },
      "dependsOn": [
        "swa"
      ]
    },
    "swaCustomDomain": {
      "type": "Microsoft.Web/staticSites/customDomains",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}/{1}', parameters('name'), 'buzzin.dotheneedful.dev')]",
      "properties": {},
      "dependsOn": [
        "swa"
      ]
    }
  },
  "outputs": {
    "hostname": {
      "type": "string",
      "metadata": {
        "description": "Default hostname of the Static Web App"
      },
      "value": "[reference('swa').defaultHostname]"
    },
    "deploymentToken": {
      "type": "securestring",
      "metadata": {
        "description": "Deployment token for GitHub Actions"
      },
      "value": "[listSecrets('swa', '2023-12-01').properties.apiKey]"
    }
  }
}